// =============================================
// Schema Completo Atualizado - dbdiagram.io
// =============================================

Table users_profile {
  id uuid [pk, default: `gen_random_uuid()`]
  nome text
  telefone varchar [not null]
  imagem text
  descricao text
  redes_sociais jsonb [default: '{}']
}

Table adm_credenciais {
  id bigint [pk, increment]
  codigo_especial text [not null]
  senha_adm text [not null]
  ativo boolean [default: true]
  funcao text
  fk_user_profile_id uuid [ref: > users_profile.id, not null]
}

Table banner_config {
  id integer [pk]
  carrossel_banners jsonb [default: '[]']
}

Table categorias {
  id bigint [pk, increment]
  nome text [not null]
  tipo text [not null]
  data_criacao timestamp [default: `now()`, not null]
  slug text [not null]
  fk_adms_id uuid [not null]
}

Table livros {
  id bigint [pk, increment]
  direitos_de_publicacao boolean [not null]
  conteudo_por_IA boolean [not null]
  imagens_explicitas boolean [not null]
  publico_alvo text
  numero_edicao smallint
  data_de_publicacao date [not null]
  preco_digital numeric [not null]
  preco_fisico numeric [not null]
  titulo text [not null]
  subtitulo text [not null]
  descricao text [not null]
  autor_nome text [not null]
  autor_sobrenome text [not null]
  ativo boolean [default: true, not null]
  estado varchar [default: 'rascunho', not null]
  idioma text [not null]
  manuscrito text
  colaboradores jsonb [default: '[]']
  capa jsonb [default: '{}']
  fk_user_profile_id uuid [ref: > users_profile.id, not null]
  fk_categorias_id bigint [ref: > categorias.id]
}

Table comentarios {
  id bigint [pk, increment]
  data timestamp [default: `now()`, not null]
  texto text [not null]
  fk_user_profile_id uuid [ref: > users_profile.id, not null]
  fk_livros_id bigint [ref: > livros.id]
}

Table denuncias {
  id bigint [pk, increment]
  data timestamp [default: `now()`, not null]
  descricao text [not null]
  fk_user_profile_id uuid [ref: > users_profile.id, not null]
  fk_categorias_id bigint [ref: > categorias.id]
}

Table enderecos {
  id bigint [pk, increment]
  estado varchar [not null]
  bairro text [not null]
  rua text [not null]
  num integer [not null]
  cep varchar [not null]
  cidade text [not null]
  complemento text
  fk_user_profile_id uuid [ref: > users_profile.id, not null]
}

Table met_pagamentos {
  id bigint [pk, increment]
  nome text [not null]
}

Table usuarios_cartoes {
  id bigint [pk, increment]
  token_pagamento text
  final_cartao varchar [not null]
  bandeira_varchar varchar [not null]
  nome_no_cartao text [not null]
  data_expiracao varchar [not null]
  fk_user_profile_id uuid [ref: > users_profile.id, not null]
}

Table vendas {
  id bigint [pk, increment]
  data timestamp [default: `now()`, not null]
  total numeric [not null]
  transacao_id text [not null]
  status_pagamento text [not null]
  endereco_entrega jsonb [not null]
  fk_met_pagamentos_id bigint [ref: > met_pagamentos.id, not null]
  fk_user_profile_id uuid [ref: > users_profile.id, not null]
}

Table itens_venda {
  id bigint [pk, increment]
  qtd bigint [not null]
  subtotal numeric [not null]
  fk_livros_itens_id bigint [ref: > livros.id, not null]
  fk_vendas_id bigint [ref: > vendas.id, not null]
}

Table cupons {
  id bigint [pk, increment]
  codigo text [unique, not null]
  nome text [not null]
  valor numeric [not null]
  tipo_desconto text [not null]
  universal boolean [default: false, not null]
  ativo boolean [default: true, not null]
  data_inicio timestamp [not null]
  data_fim timestamp [not null]
  limite_uso_total integer
  limite_usuario integer [default: 1]
  valor_minimo_compra numeric [default: 0]
  data_criacao timestamp [default: `now()`]
  data_atualizacao timestamp [default: `now()`]
  fk_livros_id bigint [ref: > livros.id]
  fk_adm_credenciais_id bigint [ref: > adm_credenciais.id]
}

Table revisoes {
  id bigint [pk, increment]
  arquivo text [not null]
  data timestamp [default: `now()`, not null]
  apontamento text
  fk_user_profile_id uuid [ref: > users_profile.id, not null]
  fk_livro_id bigint [ref: > livros.id, not null]
}

Table notificacoes {
  id bigint [pk, increment]
  titulo text [not null]
  texto text [not null]
  tipo text [not null]
  data timestamp [default: `now()`, not null]
  ADM boolean [default: false, not null]
  metadados jsonb [default: '{}']
  fk_user_profile_id uuid [ref: > users_profile.id]
}

Table notificacoes_lidas {
  id bigint [pk, increment]
  data_leitura timestamp [default: `now()`, not null]
  fk_notificacao_id bigint [ref: > notificacoes.id, not null]
  fk_user_profile_id uuid [ref: > users_profile.id, not null]
}
