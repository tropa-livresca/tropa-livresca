      "html": "<div class=\"bg-[#fff8c9] p-12 font-[Arial,sans-serif]\" data-kid=\"0\">\n  <nav aria-label=\"Paginação\" class=\"flex items-center justify-center gap-6\" data-kid=\"1\">\n    \n    <button disabled class=\"flex items-center gap-2 rounded-full bg-[#fffdf7] px-6 py-3 text-sm font-semibold text-[#7a6a5b] border border-[rgba(77,31,24,0.15)] opacity-70 cursor-not-allowed select-none\" data-kid=\"2\">\n      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" data-kid=\"3\">\n        <path d=\"M15 18l-6-6 6-6\" data-kid=\"4\"></path>\n      </svg>\n      Anterior\n    </button>\n\n    \n    <div class=\"text-center leading-tight\" data-kid=\"5\">\n      <span class=\"block text-base text-[#432c28] font-semibold\" data-kid=\"6\">Página 1 de 5</span>\n      <span class=\"block text-xs text-[#7a6a5b] mt-1\" data-kid=\"7\">(Total: 54 livros)</span>\n    </div>\n\n    \n    <button class=\"flex items-center gap-2 rounded-full bg-[#4d1f18] px-6 py-3 text-sm font-semibold text-white shadow-[0_4px_15px_rgba(0,0,0,0.10)] transition-colors duration-300 hover:bg-[#6a2b22] cursor-pointer select-none\" data-kid=\"8\">\n      Próximo\n      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" data-kid=\"9\">\n        <path d=\"M9 18l6-6-6-6\" data-kid=\"10\"></path>\n      </svg>\n    </button>\n  </nav>\n</div>",
